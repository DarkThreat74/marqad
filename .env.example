# Copy this file to .env.local and fill in your values.
# The Speechmatics API key is NOT here — it goes in Supabase as a secret,
# never in frontend code or git.
#
# Supabase Edge Function Secrets (set in Supabase dashboard, not here):
# - SPEECHMATICS_API_KEY: Your Speechmatics API key
# - SUPABASE_SERVICE_ROLE_KEY: For the usage edge function (bypasses RLS)
# - GEMINI_API_KEY: Your Google AI Studio Gemini API key (for Phase 2 AI reasoning)

NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
NEXT_PUBLIC_SPEECHMATICS_TOKEN_ENDPOINT=your-token-endpoint-url
